# Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=casa_geyse_reservas
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=sua_chave_jwt_secreta_muito_segura_aqui
JWT_EXPIRES_IN=7d

# Efí Bank (Pix)
EFI_CLIENT_ID=seu_client_id_efi
EFI_CLIENT_SECRET=seu_client_secret_efi
EFI_SANDBOX=true
EFI_WEBHOOK_SECRET=seu_webhook_secret

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_evolution
EVOLUTION_INSTANCE=casa_geyse

# Cloudflare R2 (Fotos)
R2_ACCESS_KEY=seu_access_key_r2
R2_SECRET_KEY=seu_secret_key_r2
R2_BUCKET=casa-geyse-media
R2_ENDPOINT=https://seu-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.casadageyse.com.br

# WhatsApp Admin
ADMIN_WHATSAPP=5548999999999

# Configurações de Negócio
SPLIT_PLATFORM_PERCENT=20
SPLIT_HOUSE_PERCENT=60
SPLIT_COMPANION_PERCENT=20
PIX_EXPIRY_MINUTES=10
RENEWAL_ALERT_MINUTES=15
NPS_DELAY_MINUTES=60
REACTIVATION_DAYS=15
VIP_MIN_RESERVATIONS=10
LOYALTY_POINTS_PER_100=10
LOYALTY_POINTS_FOR_REWARD=500

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
